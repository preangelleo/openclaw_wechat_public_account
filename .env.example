# Deployment Security (Required for oc.macroalpha.io hosting)
ADMIN_API_KEY=your_admin_api_key_here

# Note: All business logic credentials (WeChat SDK, OpenRouter, Database) 
# must NOT be stored in exactly this environment for production usage.
# Instead, they are passed by the caller as arguments or API JSON payload.

# --- Optional Webhook Fallbacks ---
# If you are not using URL string parameters for the Webhook callback,
# you can use these local fallbacks for your single-server deployment.
# APPID=wx1234567890
# SECRET=your_secret_here
# WECHAT_TOKEN=your_token
# WECHAT_AES_KEY=your_aes_key
# OPENROUTER_API_KEY=sk-or-v1-your_key
# BOT_PERSONA="You are a helpful AI assistant."
# WELCOME_MESSAGE="Welcome to our Official Account!"
